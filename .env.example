# =====================================================================
# Mnemo Enterprise — environment template
# Copy to .env and fill before `docker compose up -d`.
# =====================================================================

# ---- License (required) ----
# JWT issued by Mnemo after Stripe purchase. Bound to your org name +
# expiry. Validated on boot — invalid/expired keys refuse to start.
GETMNEMO_LICENSE_KEY=

# ---- Image version ----
GETMNEMO_VERSION=latest

# ---- Postgres ----
POSTGRES_PASSWORD=change-me-now

# ---- Auth secrets (generate with: openssl rand -base64 48) ----
MEMORY_API_JWT_ACCESS_SECRET=
MEMORY_API_JWT_REFRESH_SECRET=

# ---- LLM provider ----
# Set EITHER OpenAI OR Bedrock. Air-gapped installs can use Ollama (see docs).
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- Air-gapped mode ----
# Set to 1 to disable all outbound network calls (OpenAI/Bedrock/Resend).
# Requires Ollama or another local model — see docs/AIR_GAPPED.md.
GETMNEMO_AIR_GAPPED=0

# ---- Worker tuning ----
WORKER_CONCURRENCY=2

# ---- Observability (optional, profile=observability) ----
GRAFANA_ADMIN_PASSWORD=
